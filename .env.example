# ─────────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────
# AWS Textract
# ─────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ─────────────────────────────────────────────────────────────
# Anthropic (Claude) — parsing fallback + AI compliance review
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────
# Resend (transactional email)
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@certtrack.io

# ─────────────────────────────────────────────────────────────
# Twilio (SMS upload reminders — optional)
# ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# ─────────────────────────────────────────────────────────────
# Stripe
# ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_STARTER_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=
STRIPE_SCALE_PRICE_ID=
STRIPE_UNLIMITED_PRICE_ID=

# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
UPLOAD_TOKEN_SECRET=replace-with-a-long-random-string

# Auth enforcement (Phase 8). When "true", unauthenticated users are
# redirected to /auth/login and the active org comes from the signed-in
# user. When unset/false (dev/demo), no login is required and the
# hardcoded dev org below is used.
NEXT_PUBLIC_REQUIRE_AUTH=false

# ─────────────────────────────────────────────────────────────
# Development
# During Phase 1–7 auth is deferred. This is the hardcoded test
# org id used by the dev app. It must match the seeded org in
# supabase/seed.sql.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_DEV_ORG_ID=00000000-0000-0000-0000-000000000001
